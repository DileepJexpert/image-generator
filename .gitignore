# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Backend (Maven / Java)
backend/target/
backend/bin/
backend/out/
# Maven wrapper: keep mvnw/.mvn, ignore the downloaded distribution cache
.mvn/wrapper/maven-wrapper.jar

# Frontend (Flutter)
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/build/
frontend/.packages

# NOTE: freezed/json_serializable generated sources (*.freezed.dart, *.g.dart)
# are intentionally committed (see frontend/lib/editor/model/). They depend only
# on the stable freezed_annotation runtime, so a fresh clone compiles without
# running build_runner — regenerate them after changing a model.

# Local data / assets
data/
*.log

# ComfyUI host bind mounts: keep the folder structure (.gitkeep) but never
# commit the multi-GB checkpoints or generated outputs.
media/comfyui/models/**
!media/comfyui/models/
!media/comfyui/models/**/
!media/comfyui/models/**/.gitkeep
media/comfyui/output/**
!media/comfyui/output/
!media/comfyui/output/.gitkeep
