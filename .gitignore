# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Backend (Maven / Java)
backend/target/
backend/bin/
backend/out/
# Maven wrapper: keep mvnw/.mvn, ignore the downloaded distribution cache
.mvn/wrapper/maven-wrapper.jar

# Frontend (Flutter)
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/build/
frontend/.packages
frontend/pubspec.lock

# Generated sources (recreated by build_runner; the Docker build regenerates them)
frontend/**/*.freezed.dart
frontend/**/*.g.dart

# Local data / assets
data/
*.log
