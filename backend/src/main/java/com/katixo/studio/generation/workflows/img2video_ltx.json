{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{IMAGE_NAME}}"
    }
  },
  "2": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ltx-video-2b-v0.9.5.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{PROMPT}}",
      "clip": ["2", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["2", 1]
    }
  },
  "5": {
    "class_type": "LTXVImgToVideo",
    "inputs": {
      "vae": ["2", 2],
      "image": ["1", 0],
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "length": "{{FRAMES}}",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": 30,
      "cfg": 3.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0,
      "model": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0]
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 2]
    }
  },
  "8": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["7", 0],
      "frame_rate": "{{FPS}}",
      "loop_count": 0,
      "filename_prefix": "katixo_video",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
